{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas.graph.schema.json",
  "title": "Atlas Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nodes",
    "routes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "district",
        "zone",
        "inputs",
        "outputs",
        "dependencies",
        "fallbacks",
        "criticality"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "district": {
          "type": "string",
          "enum": [
            "Acquisition",
            "Operations",
            "Revenue",
            "Experience"
          ]
        },
        "zone": {
          "type": "string",
          "pattern": "^0[1-5]$"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "criticality": {
          "type": "string",
          "enum": [
            "low",
            "med",
            "high"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "degraded",
            "down"
          ]
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "path",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "type": {
          "type": "string",
          "enum": [
            "primary",
            "secondary",
            "fallback"
          ]
        },
        "reliability": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "avg_handoff_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
