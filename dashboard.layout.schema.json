{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dashboard.layout.schema.json",
  "title": "Dashboard Layout",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "role",
    "widgets"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "admin"
      ]
    },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "x",
          "y",
          "w",
          "h",
          "enabled",
          "settings"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "w": {
            "type": "integer",
            "minimum": 1
          },
          "h": {
            "type": "integer",
            "minimum": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "settings": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "title": {
                "type": "string"
              },
              "refreshSec": {
                "type": "integer",
                "minimum": 0
              },
              "visible": {
                "type": "boolean"
              },
              "size": {
                "type": "string",
                "enum": [
                  "small",
                  "medium",
                  "large",
                  "custom"
                ]
              }
            }
          }
        }
      }
    }
  }
}
