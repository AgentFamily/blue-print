{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentc.local/schemas/server-monitor-health-v1.json",
  "title": "Server Monitor Agent Health Payload",
  "type": "object",
  "required": ["ok", "generatedAt", "host", "signals", "maintenance"],
  "properties": {
    "ok": { "type": "boolean", "const": true },
    "generatedAt": { "type": "string", "format": "date-time" },
    "host": {
      "type": "object",
      "required": ["hostname", "os", "controlPanel"],
      "properties": {
        "hostname": { "type": "string" },
        "os": { "type": "string" },
        "controlPanel": { "type": "string" }
      },
      "additionalProperties": true
    },
    "signals": {
      "type": "object",
      "required": ["cpu", "ram", "disk", "uptime"],
      "properties": {
        "cpu": {
          "type": "object",
          "required": ["percent"],
          "properties": {
            "percent": { "type": "number", "minimum": 0, "maximum": 100 },
            "avg5mPercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        },
        "ram": {
          "type": "object",
          "required": ["percent"],
          "properties": {
            "percent": { "type": "number", "minimum": 0, "maximum": 100 },
            "avg5mPercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        },
        "disk": {
          "type": "object",
          "required": ["usedPercent", "freeGb"],
          "properties": {
            "usedPercent": { "type": "number", "minimum": 0, "maximum": 100 },
            "freeGb": { "type": "number", "minimum": 0 },
            "totalGb": { "type": ["number", "null"], "minimum": 0 }
          },
          "additionalProperties": true
        },
        "uptime": {
          "type": "object",
          "required": ["seconds"],
          "properties": {
            "seconds": { "type": "number", "minimum": 0 },
            "lastRebootAt": { "type": ["string", "null"], "format": "date-time" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "maintenance": {
      "type": "object",
      "required": ["pendingOsUpdates", "pleskUpdatesAvailable", "ssl"],
      "properties": {
        "pendingOsUpdates": { "type": ["integer", "null"], "minimum": 0 },
        "pleskUpdatesAvailable": { "type": ["boolean", "null"] },
        "ssl": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["domain", "status"],
            "properties": {
              "domain": { "type": "string" },
              "status": { "type": "string", "enum": ["valid", "expiring", "expired", "unknown"] },
              "expiresAt": { "type": ["string", "null"], "format": "date-time" },
              "daysRemaining": { "type": ["integer", "null"] }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
